---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Studio — Bouw je website">

  <!-- HEADER -->
  <header class="flex items-center justify-between px-8 py-4 border-b border-zinc-800">
    <div>
      <span class="font-mono text-xs text-zinc-500 tracking-widest uppercase">KV Studio</span>
      <h1 class="text-sm font-semibold text-zinc-100 mt-0.5">Website Configurator</h1>
    </div>
    <div class="flex items-center gap-3">
      <span id="progress-label" class="font-mono text-xs text-zinc-500">Stap 1 / 4</span>
      <div class="flex gap-1.5">
        {[1,2,3,4].map(n => (
          <div id={`dot-${n}`} class={`w-2 h-2 rounded-full transition-colors ${n === 1 ? 'bg-blue-500' : 'bg-zinc-700'}`}></div>
        ))}
      </div>
    </div>
  </header>

  <!-- MAIN: sidebar + preview -->
  <div class="flex h-[calc(100vh-57px)]">

    <!-- SIDEBAR (links) -->
    <aside class="w-96 shrink-0 border-r border-zinc-800 flex flex-col overflow-hidden">

      <!-- Stappen container -->
      <div id="steps" class="flex-1 overflow-y-auto">

        <!-- ── STAP 1: Template ── -->
        <div id="step-1" class="p-6">
          <p class="font-mono text-xs text-blue-400 tracking-widest mb-1 uppercase">01</p>
          <h2 class="text-lg font-semibold mb-1">Kies je template</h2>
          <p class="text-xs text-zinc-500 mb-5">Selecteer de basisstijl die het best past bij jouw merk.</p>

          <div class="flex flex-col gap-3">
            {[
              { id: 'tech',   label: 'Clean Tech',    sub: 'Minimaal, modern, professioneel', accent: '#2563EB' },
              { id: 'luxury', label: 'Dark Luxury',   sub: 'Elegant, exclusief, donker',      accent: '#E8C87A' },
              { id: 'agency', label: 'Bold Agency',   sub: 'Groot, brutaal, impactvol',       accent: '#FF3B00' },
              { id: 'craft',  label: 'Warm Craft',    sub: 'Persoonlijk, warm, ambachtelijk', accent: '#B45309' },
            ].map(t => (
              <button
                data-tpl={t.id}
                class="template-btn text-left p-4 rounded border border-zinc-700 hover:border-zinc-400 transition-all group relative"
              >
                <!-- Kleurblok -->
                <div class="flex items-center gap-3 mb-2">
                  <span class="w-3 h-3 rounded-full shrink-0" style={`background:${t.accent}`}></span>
                  <span class="font-semibold text-sm">{t.label}</span>
                </div>
                <p class="text-xs text-zinc-500">{t.sub}</p>
                <span class="absolute top-3 right-3 text-blue-400 opacity-0 group-[.active]:opacity-100 text-xs font-mono">✓</span>
              </button>
            ))}
          </div>
        </div>

        <!-- ── STAP 2: Aanpassen ── -->
        <div id="step-2" class="p-6 hidden">
          <p class="font-mono text-xs text-blue-400 tracking-widest mb-1 uppercase">02</p>
          <h2 class="text-lg font-semibold mb-1">Stijl aanpassen</h2>
          <p class="text-xs text-zinc-500 mb-5">Kies kleuren, thema en lettertype.</p>

          <!-- Accentkleur -->
          <div class="mb-6">
            <label class="font-mono text-xs text-zinc-400 tracking-widest uppercase block mb-3">Accentkleur</label>
            <div class="flex flex-wrap gap-2 mb-3" id="color-presets">
              {[
                ['#2563EB','Blauw'],['#E8C87A','Goud'],['#B45309','Amber'],
                ['#16A34A','Groen'],['#DC2626','Rood'],['#7C3AED','Paars'],
                ['#0891B2','Cyaan'],['#DB2777','Roze'],
              ].map(([hex, naam]) => (
                <button
                  data-color={hex}
                  class="color-btn w-7 h-7 rounded-full border-2 border-transparent hover:scale-110 transition-transform"
                  style={`background:${hex}`}
                  title={naam}
                ></button>
              ))}
            </div>
            <div class="flex items-center gap-2">
              <input type="color" id="color-custom" value="#2563EB" class="w-8 h-8 rounded cursor-pointer border-0 bg-transparent" />
              <span class="font-mono text-xs text-zinc-500">Eigen kleur kiezen</span>
            </div>
          </div>

          <!-- Thema -->
          <div class="mb-6">
            <label class="font-mono text-xs text-zinc-400 tracking-widest uppercase block mb-3">Thema</label>
            <div class="grid grid-cols-2 gap-2">
              {[
                { id: 'licht',  label: 'Licht', icon: '☀️' },
                { id: 'donker', label: 'Donker', icon: '🌙' },
              ].map(t => (
                <button data-thema={t.id} class="thema-btn p-3 rounded border border-zinc-700 hover:border-zinc-400 text-sm flex items-center gap-2 transition-all">
                  <span>{t.icon}</span> {t.label}
                </button>
              ))}
            </div>
          </div>

          <!-- Font -->
          <div>
            <label class="font-mono text-xs text-zinc-400 tracking-widest uppercase block mb-3">Lettertype</label>
            <div class="flex flex-col gap-2">
              {[
                { id: 'grotesk', label: 'Space Grotesk', sub: 'Modern & tech' },
                { id: 'serif',   label: 'Playfair Display', sub: 'Elegant & klassiek' },
                { id: 'sans',    label: 'DM Sans', sub: 'Neutraal & vriendelijk' },
              ].map(f => (
                <button data-font={f.id} class="font-btn text-left p-3 rounded border border-zinc-700 hover:border-zinc-400 transition-all">
                  <span class="text-sm font-medium">{f.label}</span>
                  <span class="text-xs text-zinc-500 ml-2">{f.sub}</span>
                </button>
              ))}
            </div>
          </div>
        </div>

        <!-- ── STAP 3: Componenten ── -->
        <div id="step-3" class="p-6 hidden">
          <p class="font-mono text-xs text-blue-400 tracking-widest mb-1 uppercase">03</p>
          <h2 class="text-lg font-semibold mb-1">Kies je stijl</h2>
          <p class="text-xs text-zinc-500 mb-5">Selecteer hoe je secties eruit moeten zien.</p>

          <!-- Hero stijl -->
          <div class="mb-6">
            <label class="font-mono text-xs text-zinc-400 tracking-widest uppercase block mb-3">Hero sectie</label>
            <div class="flex flex-col gap-2">
              {[
                { id: 'split',    label: 'Split layout', sub: 'Naam groot, tekst + knop naast elkaar' },
                { id: 'centered', label: 'Gecentreerd',  sub: 'Alles in het midden, symme trisch' },
                { id: 'minimal',  label: 'Minimaal',     sub: 'Simpel, enkel tekst en een knop' },
              ].map(h => (
                <button data-hero={h.id} class="hero-btn text-left p-3 rounded border border-zinc-700 hover:border-zinc-400 transition-all">
                  <span class="text-sm font-medium block">{h.label}</span>
                  <span class="text-xs text-zinc-500">{h.sub}</span>
                </button>
              ))}
            </div>
          </div>

          <!-- Projecten stijl -->
          <div>
            <label class="font-mono text-xs text-zinc-400 tracking-widest uppercase block mb-3">Projecten weergave</label>
            <div class="grid grid-cols-2 gap-2">
              {[
                { id: 'lijst', label: 'Lijst',  icon: '☰' },
                { id: 'grid',  label: 'Grid',   icon: '⊞' },
              ].map(p => (
                <button data-proj={p.id} class="proj-btn p-4 rounded border border-zinc-700 hover:border-zinc-400 text-center transition-all">
                  <div class="text-2xl mb-1">{p.icon}</div>
                  <div class="text-sm">{p.label}</div>
                </button>
              ))}
            </div>
          </div>
        </div>

        <!-- ── STAP 4: Samenvatting ── -->
        <div id="step-4" class="p-6 hidden">
          <p class="font-mono text-xs text-blue-400 tracking-widest mb-1 uppercase">04</p>
          <h2 class="text-lg font-semibold mb-1">Jouw keuze</h2>
          <p class="text-xs text-zinc-500 mb-5">Verstuur je configuratie en ik neem contact op.</p>

          <!-- Samenvatting -->
          <div class="bg-zinc-900 rounded border border-zinc-800 p-4 mb-6 font-mono text-xs space-y-2 text-zinc-400">
            <div class="flex justify-between"><span class="text-zinc-600">Template</span><span id="sum-tpl"  class="text-zinc-200">—</span></div>
            <div class="flex justify-between"><span class="text-zinc-600">Thema</span>   <span id="sum-thema" class="text-zinc-200">—</span></div>
            <div class="flex justify-between items-center"><span class="text-zinc-600">Accent</span><span id="sum-color" class="w-4 h-4 rounded-full inline-block"></span></div>
            <div class="flex justify-between"><span class="text-zinc-600">Font</span>    <span id="sum-font"  class="text-zinc-200">—</span></div>
            <div class="flex justify-between"><span class="text-zinc-600">Hero</span>    <span id="sum-hero"  class="text-zinc-200">—</span></div>
            <div class="flex justify-between"><span class="text-zinc-600">Projecten</span><span id="sum-proj" class="text-zinc-200">—</span></div>
          </div>

          <!-- Formulier -->
          <form id="contact-form" class="flex flex-col gap-3" netlify>
            <input type="hidden" name="form-name" value="studio-configuratie" />
            <input type="hidden" name="configuratie" id="field-config" />
            <div>
              <label class="font-mono text-[0.6rem] text-zinc-500 tracking-widest uppercase block mb-1">Naam</label>
              <input name="naam" type="text" required placeholder="Jan Janssen"
                class="w-full bg-zinc-900 border border-zinc-700 rounded px-3 py-2 text-sm text-zinc-100 focus:outline-none focus:border-blue-500 placeholder:text-zinc-600" />
            </div>
            <div>
              <label class="font-mono text-[0.6rem] text-zinc-500 tracking-widest uppercase block mb-1">E-mail</label>
              <input name="email" type="email" required placeholder="jan@example.be"
                class="w-full bg-zinc-900 border border-zinc-700 rounded px-3 py-2 text-sm text-zinc-100 focus:outline-none focus:border-blue-500 placeholder:text-zinc-600" />
            </div>
            <div>
              <label class="font-mono text-[0.6rem] text-zinc-500 tracking-widest uppercase block mb-1">Opmerkingen (optioneel)</label>
              <textarea name="opmerkingen" rows="3" placeholder="Verdere wensen..."
                class="w-full bg-zinc-900 border border-zinc-700 rounded px-3 py-2 text-sm text-zinc-100 focus:outline-none focus:border-blue-500 placeholder:text-zinc-600 resize-none"></textarea>
            </div>
            <button type="submit"
              class="w-full bg-blue-600 hover:bg-blue-500 text-white py-2.5 text-sm font-medium rounded transition-colors mt-1">
              Verstuur mijn configuratie →
            </button>
          </form>
          <div id="form-success" class="hidden text-center py-6">
            <div class="text-3xl mb-3">✓</div>
            <p class="text-sm font-semibold text-zinc-100">Bedankt! Ik neem snel contact op.</p>
          </div>
        </div>

      </div>

      <!-- Navigatieknoppen -->
      <div class="border-t border-zinc-800 p-4 flex gap-3">
        <button id="btn-prev" class="flex-1 py-2 text-sm border border-zinc-700 hover:border-zinc-400 text-zinc-400 hover:text-zinc-100 transition-all rounded hidden">
          ← Vorige
        </button>
        <button id="btn-next" class="flex-1 py-2 text-sm bg-blue-600 hover:bg-blue-500 text-white rounded transition-colors font-medium">
          Volgende →
        </button>
      </div>
    </aside>

    <!-- PREVIEW (rechts) -->
    <main class="flex-1 flex flex-col bg-zinc-900">
      <div class="flex items-center justify-between px-4 py-2 border-b border-zinc-800">
        <span class="font-mono text-xs text-zinc-600">Live preview</span>
        <div class="flex items-center gap-1.5">
          <span class="w-2.5 h-2.5 rounded-full bg-zinc-700"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-zinc-700"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-zinc-700"></span>
        </div>
      </div>
      <div class="flex-1 overflow-hidden">
        <iframe
          id="preview-frame"
          src="/preview?template=tech&thema=licht&accent=2563EB&font=grotesk&hero=split&proj=lijst"
          class="w-full h-full border-0"
          title="Live preview"
        ></iframe>
      </div>
    </main>

  </div>

</Layout>

<script is:inline>
  // ── STATE ────────────────────────────────────────────────
  const state = { step: 1, template: 'tech', thema: 'licht', accent: '#2563EB', font: 'grotesk', hero: 'split', proj: 'lijst' };
  const TOTAL = 4;

  // ── HELPERS ──────────────────────────────────────────────
  function buildUrl() {
    const hex = state.accent.replace('#', '');
    return `/preview?template=${state.template}&thema=${state.thema}&accent=${hex}&font=${state.font}&hero=${state.hero}&proj=${state.proj}`;
  }

  function updatePreview() {
    document.getElementById('preview-frame').src = buildUrl();
  }

  function setActive(selector, value, attr) {
    document.querySelectorAll(selector).forEach(el => {
      el.classList.toggle('active', el.dataset[attr] === value);
      el.classList.toggle('border-blue-500', el.dataset[attr] === value);
      el.classList.toggle('border-zinc-700', el.dataset[attr] !== value);
    });
  }

  function showStep(n) {
    for (let i = 1; i <= TOTAL; i++) {
      const el = document.getElementById(`step-${i}`);
      if (el) el.classList.toggle('hidden', i !== n);
      const dot = document.getElementById(`dot-${i}`);
      if (dot) {
        dot.className = `w-2 h-2 rounded-full transition-colors ${i <= n ? 'bg-blue-500' : 'bg-zinc-700'}`;
      }
    }
    document.getElementById('progress-label').textContent = `Stap ${n} / ${TOTAL}`;
    document.getElementById('btn-prev').classList.toggle('hidden', n === 1);
    document.getElementById('btn-next').textContent = n === TOTAL ? '' : 'Volgende →';
    document.getElementById('btn-next').classList.toggle('hidden', n === TOTAL);
    if (n === TOTAL) updateSummary();
  }

  function updateSummary() {
    const labels = { tech: 'Clean Tech', luxury: 'Dark Luxury', agency: 'Bold Agency', craft: 'Warm Craft' };
    const fLabels = { grotesk: 'Space Grotesk', serif: 'Playfair', sans: 'DM Sans' };
    const hLabels = { split: 'Split layout', centered: 'Gecentreerd', minimal: 'Minimaal' };
    document.getElementById('sum-tpl').textContent   = labels[state.template] || state.template;
    document.getElementById('sum-thema').textContent = state.thema.charAt(0).toUpperCase() + state.thema.slice(1);
    document.getElementById('sum-color').style.background = state.accent;
    document.getElementById('sum-font').textContent  = fLabels[state.font] || state.font;
    document.getElementById('sum-hero').textContent  = hLabels[state.hero] || state.hero;
    document.getElementById('sum-proj').textContent  = state.proj.charAt(0).toUpperCase() + state.proj.slice(1);
    document.getElementById('field-config').value   = JSON.stringify(state);
  }

  // ── TEMPLATE KNOPPEN ─────────────────────────────────────
  document.querySelectorAll('.template-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      state.template = btn.dataset.tpl;
      const accents = { tech: '#2563EB', luxury: '#E8C87A', agency: '#FF3B00', craft: '#B45309' };
      const themas  = { tech: 'licht',   luxury: 'donker',  agency: 'donker', craft: 'licht'  };
      state.accent  = accents[state.template];
      state.thema   = themas[state.template];
      document.querySelectorAll('.template-btn').forEach(b => b.classList.remove('active','border-blue-500'));
      btn.classList.add('active','border-blue-500');
      updatePreview();
    });
  });

  // ── KLEUR PRESETS ─────────────────────────────────────────
  document.querySelectorAll('.color-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      state.accent = btn.dataset.color;
      document.getElementById('color-custom').value = state.accent;
      document.querySelectorAll('.color-btn').forEach(b => b.classList.remove('ring-2','ring-white'));
      btn.classList.add('ring-2','ring-white');
      updatePreview();
    });
  });
  document.getElementById('color-custom').addEventListener('input', e => {
    state.accent = e.target.value;
    updatePreview();
  });

  // ── THEMA ─────────────────────────────────────────────────
  document.querySelectorAll('.thema-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      state.thema = btn.dataset.thema;
      setActive('.thema-btn', state.thema, 'thema');
      updatePreview();
    });
  });

  // ── FONT ──────────────────────────────────────────────────
  document.querySelectorAll('.font-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      state.font = btn.dataset.font;
      setActive('.font-btn', state.font, 'font');
      updatePreview();
    });
  });

  // ── HERO ──────────────────────────────────────────────────
  document.querySelectorAll('.hero-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      state.hero = btn.dataset.hero;
      setActive('.hero-btn', state.hero, 'hero');
      updatePreview();
    });
  });

  // ── PROJECTEN ─────────────────────────────────────────────
  document.querySelectorAll('.proj-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      state.proj = btn.dataset.proj;
      setActive('.proj-btn', state.proj, 'proj');
      updatePreview();
    });
  });

  // ── NAVIGATIE ─────────────────────────────────────────────
  document.getElementById('btn-next').addEventListener('click', () => {
    if (state.step < TOTAL) { state.step++; showStep(state.step); }
  });
  document.getElementById('btn-prev').addEventListener('click', () => {
    if (state.step > 1) { state.step--; showStep(state.step); }
  });

  // ── FORMULIER ─────────────────────────────────────────────
  document.getElementById('contact-form').addEventListener('submit', async e => {
    e.preventDefault();
    const form = e.target;
    const data = new FormData(form);
    try {
      await fetch('/', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: new URLSearchParams(data).toString() });
    } catch(_) {}
    form.classList.add('hidden');
    document.getElementById('form-success').classList.remove('hidden');
  });

  // Init
  showStep(1);
  // Zet eerste template knop actief
  document.querySelector('[data-tpl="tech"]').classList.add('active','border-blue-500');
  document.querySelector('[data-thema="licht"]').classList.add('border-blue-500');
  document.querySelector('[data-font="grotesk"]').classList.add('border-blue-500');
  document.querySelector('[data-hero="split"]').classList.add('border-blue-500');
  document.querySelector('[data-proj="lijst"]').classList.add('border-blue-500');
</script>

